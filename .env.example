# Notion integration token
# Create one at https://www.notion.so/my-integrations
# Then share your Blog database with the integration (⋯ menu → Connections)
NOTION_TOKEN=secret_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Optional: override the database ID (defaults to the blog database)
